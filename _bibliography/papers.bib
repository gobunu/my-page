@article{gong2026lcudiff,
  abbr        = {arXiv},
  bibtex_show = {true},
  title       = {{LCUDiff}: Latent Capacity Upgrade Diffusion for Faithful Human Body Restoration},
  shortname   = {LCUDiff},
  author      = {Jue Gong and Zihan Zhou and Jingkai Wang and Shu Li and Libo Liu and Jianliang Lan and Yulun Zhang},
  journal     = {arXiv preprint arXiv:2602.04406},
  year        = {2026},
  arxiv       = {2602.04406},
  pdf         = {https://arxiv.org/pdf/2602.04406.pdf},
  code        = {https://github.com/gobunu/LCUDiff},
  abstract    = {We propose LCUDiff, a stable one-step framework for human body restoration that upgrades latent diffusion from the 4-channel latent space to a 16-channel latent space. The method uses channel splitting distillation and prior-preserving adaptation to improve fidelity while keeping one-step efficiency, and further introduces a decoder router for per-sample decoder routing under diverse restoration conditions.},
  selected    = {true}
}

